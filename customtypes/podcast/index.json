{
  "format": "custom",
  "id": "podcast",
  "label": "Podcast",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "title": {
        "type": "StructuredText",
        "config": {
          "label": "Title",
          "single": "heading1",
          "placeholder": "Название выпуска"
        }
      },
      "description": {
        "type": "Text",
        "config": {
          "label": "Description",
          "placeholder": "Краткое описание"
        }
      },
      "date": {
        "type": "Date",
        "config": {
          "label": "Date"
        }
      },
      "author": {
        "type": "Text",
        "config": {
          "label": "Author",
          "placeholder": "Имя ведущего или гостя"
        }
      },
      "community": {
        "type": "Link",
        "config": {
          "label": "Community (optional)",
          "select": "document",
          "customtypes": ["community"]
        }
      },
      "external_link": {
        "type": "Link",
        "config": {
          "label": "Ссылка на выпуск (Spotify/Apple/др.)",
          "placeholder": "https://open.spotify.com/...",
          "select": "web"
        }
      },
      "featured": {
        "type": "Boolean",
        "config": {
          "label": "Featured"
        }
      },
      "tags": {
        "type": "Group",
        "config": {
          "label": "Tags",
          "fields": {
            "tag": {
              "type": "Link",
              "config": {
                "label": "Tag",
                "select": "document",
                "customtypes": ["tag"]
              }
            }
          }
        }
      }
    },
    "SEO & Metadata": {
      "meta_title": {
        "config": {
          "label": "Meta Title",
          "placeholder": "A title of the page used for social media and search engines"
        },
        "type": "Text"
      },
      "meta_description": {
        "config": {
          "label": "Meta Description",
          "placeholder": "A brief summary of the page"
        },
        "type": "Text"
      },
      "meta_image": {
        "config": {
          "constraint": {
            "height": 1260,
            "width": 2400
          },
          "label": "Meta Image",
          "thumbnails": []
        },
        "type": "Image"
      }
    }
  }
}
