          "fields": {
            "commentary": {
              "type": "StructuredText",
              "config": {
                "label": "Commentary",
                "placeholder": "Добавить комментарий",
                "allowTargetBlank": true,
                "multi": "paragraph,preformatted,strong,em,hyperlink,list-item,o-list-item,rtl"
              }
            },
            "author": {
              "type": "Text",
              "config": {
                "label": "Author",
                "placeholder": "Автор (опционально)"
              }
            }
          }
        }
      }
    }
  }
}
