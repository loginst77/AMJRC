{
  "format": "custom",
  "id": "torah",
  "label": "Torah",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "startDate": {
        "type": "Date",
        "config": {
          "label": "Start Date",
          "placeholder": "Дата"
        }
      },
      "enddate": {
        "type": "Date",
        "config": {
          "label": "End Date",
          "placeholder": "Дата"
        }
      },
      "bible_passage": {
        "type": "Text",
        "config": {
          "label": "Bible Passage",
          "placeholder": "Бытия 2:12-29"
        }
      },
      "commentarie": {
        "type": "Group",
        "config": {
          "label": "Commentarie",
