{
  "format": "page",
  "id": "landingpage",
  "label": "LandingPage",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "image": {
        "type": "Image",
        "config": {
          "label": "Image",
          "constraint": {
            "width": 1920,
            "height": 500
          },
          "thumbnails": []
        }
      },
      "title": {
        "type": "StructuredText",
        "config": {
          "label": "Title",
          "placeholder": "Заголовок страницы",
          "allowTargetBlank": false,
          "single": "heading1"
        }
      },
      "description": {
        "type": "StructuredText",
        "config": {
          "label": "Description",
          "placeholder": "Краткое описание",
          "allowTargetBlank": true,
          "multi": "paragraph,strong,em,hyperlink"
        }
      },
      "button_1_link": {
        "type": "Link",
        "config": {
          "label": "Button 1 Link",
          "placeholder": "Link for the first optional button",
          "select": null,
          "allowTargetBlank": false,
          "repeat": false,
          "variants": ["Primary", "Secondary"],
          "allowText": true
        }
      },
      "button_2_link": {
        "type": "Link",
        "config": {
          "label": "Button 2 Link",
          "placeholder": "Link for the second optional button",
          "select": null,
          "allowText": true,
          "variants": ["Primary", "Secondary"]
        }
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {
            "newspaper_list": {
              "type": "SharedSlice"
            },
            "book_carousel": {
              "type": "SharedSlice"
            },
            "article_list": {
              "type": "SharedSlice"
            },
            "podcast_carousel": {
              "type": "SharedSlice"
            },
            "video_carousel": {
              "type": "SharedSlice"
            },
            "team_section": {
              "type": "SharedSlice"
            },
            "history_events": {
              "type": "SharedSlice"
            },
            "info_card": {
              "type": "SharedSlice"
            },
            "qa": {
              "type": "SharedSlice"
            },
            "subscribe_to_newsletter": {
              "type": "SharedSlice"
            },
            "values_block": {
              "type": "SharedSlice"
            },
            "form": {
              "type": "SharedSlice"
            },
            "banner": {
              "type": "SharedSlice"
            },
            "big_event": {
              "type": "SharedSlice"
            },
            "card": {
              "type": "SharedSlice"
            },
            "note_banner": {
              "type": "SharedSlice"
            }
          }
        }
      }
    },
    "SEO & Metadata": {
      "meta_title": {
        "config": {
          "label": "Meta Title",
          "placeholder": "A title of the page used for social media and search engines"
        },
        "type": "Text"
      },
      "meta_description": {
        "config": {
          "label": "Meta Description",
          "placeholder": "A brief summary of the page"
        },
        "type": "Text"
      },
      "meta_image": {
        "config": {
          "constraint": {
            "height": 1260,
            "width": 2400
          },
          "label": "Meta Image",
          "thumbnails": []
        },
        "type": "Image"
      }
    }
  }
}
