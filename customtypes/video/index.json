{
  "format": "custom",
  "id": "video",
  "label": "Video",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Title",
          "placeholder": "Video title"
        }
      },
      "description": {
        "type": "StructuredText",
        "config": {
          "label": "Description",
          "placeholder": "Short summary",
          "multi": "paragraph,heading3,heading4,strong,em,hyperlink,list-item,o-list-item"
        }
      },
      "youtube_url": {
        "type": "Embed",
        "config": {
          "label": "YouTube URL",
          "placeholder": "https://www.youtube.com/watch?v=..."
        }
      },
      "date": {
        "type": "Date",
        "config": {
          "label": "Publish date"
        }
      },
      "author": {
        "type": "Text",
        "config": {
          "label": "Author (optional)",
          "placeholder": "Name"
        }
      },
      "community": {
        "type": "Link",
        "config": {
          "label": "Community (optional)",
          "select": "document",
          "customtypes": ["community"]
        }
      },
      "tags": {
        "type": "Group",
        "config": {
          "label": "Tags (optional)",
          "fields": {
            "tag": {
              "type": "Link",
              "config": {
                "label": "Tag",
                "select": "document",
                "customtypes": ["tag"]
              }
            }
          }
        }
      },
      "featured": {
        "type": "Boolean",
        "config": {
          "label": "Featured"
        }
      }
    }
  }
}
