{
  "format": "custom",
  "id": "video",
  "label": "Video",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Title",
          "placeholder": "Video title"
        }
      },
      "description": {
        "type": "StructuredText",
        "config": {
          "label": "Description",
          "placeholder": "Short summary",
          "multi": "paragraph,heading3,heading4,strong,em,hyperlink,list-item,o-list-item"
        }
      },
      "youtube_url": {
        "type": "Embed",
        "config": {
          "label": "YouTube URL",
          "placeholder": "https://www.youtube.com/watch?v=..."
        }
      },
      "date": {
        "type": "Date",
        "config": {
          "label": "Publish date"
        }
      },
      "featured": {
        "type": "Boolean",
        "config": {
          "label": "Featured",
          "placeholder": "Mark as featured"
        }
      }
    }
  }
}
