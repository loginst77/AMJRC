{
  "format": "custom",
  "id": "newspaper",
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "title": {
        "type": "StructuredText",
        "config": {
          "label": "Title",
          "placeholder": "Newspaper title",
          "allowTargetBlank": false,
          "single": "heading1"
        }
      },
      "description": {
        "type": "Text",
        "config": {
          "label": "Description",
          "placeholder": "Short description"
        }
      },
      "pdf": {
        "type": "Link",
        "config": {
          "label": "PDF",
          "select": "media"
        }
      },
      "author": {
        "type": "Text",
        "config": {
          "label": "Author (optional)",
          "placeholder": "Author name"
        }
      },
      "community": {
        "type": "Link",
        "config": {
          "label": "Community (optional)",
          "select": "document",
          "customtypes": ["community"]
        }
      },
      "featured": {
        "type": "Boolean",
        "config": {
          "label": "Featured",
          "default_value": false
        }
      },
      "tags": {
        "type": "Group",
        "config": {
          "label": "Tags (optional)",
          "fields": {
            "tag": {
              "type": "Link",
              "config": {
                "label": "Tag",
                "select": "document",
                "customtypes": ["tag"]
              }
            }
          }
        }
      }
    }
  },
  "label": "Newspaper",
  "repeatable": true,
  "status": true
}
