{
  "format": "custom",
  "id": "book",
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "image": {
        "type": "Image",
        "config": {
          "label": "Image",
          "constraint": {},
          "thumbnails": []
        }
      },
      "title": {
        "type": "StructuredText",
        "config": {
          "label": "Title",
          "placeholder": "Book title",
          "allowTargetBlank": false,
          "single": "heading1"
        }
      },
      "description": {
        "type": "Text",
        "config": {
          "label": "Description",
          "placeholder": "Short description"
        }
      },
      "tags": {
        "type": "Group",
        "config": {
          "label": "Tags (optional)",
          "fields": {
            "tag": {
              "type": "Link",
              "config": {
                "label": "Tag",
                "select": "document",
                "customtypes": ["tag"]
              }
            }
          }
        }
      },
      "date_of_release": {
        "type": "Number",
        "config": {
          "label": "Year of Release",
          "placeholder": "2026"
        }
      },
      "author": {
        "type": "Text",
        "config": {
          "label": "Author",
          "placeholder": "Author name"
        }
      },
      "buy_link": {
        "type": "Link",
        "config": {
          "label": "Buy Link",
          "placeholder": "https://...",
          "select": "web"
        }
      },
      "featured": {
        "type": "Boolean",
        "config": {
          "label": "Featured",
          "default_value": false
        }
      }
    }
  },
  "label": "Book",
  "repeatable": true,
  "status": true
}
